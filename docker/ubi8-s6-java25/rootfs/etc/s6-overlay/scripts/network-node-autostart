#!/command/with-contenv bash
set -euo pipefail

FLAG="/opt/hgcapp/services-hedera/HapiApp2.0/state/network-node.enabled"
if [ -f "${FLAG}" ]; then
  # Use s6-svc rather than s6-rc to avoid nested lock contention.
  # s6-rc holds its transaction lock during boot; calling s6-rc again from
  # within a oneshot causes "unable to take locks: Resource busy" and crashes
  # the container.  s6-svc communicates directly with the already-running
  # s6-supervise daemon for network-node (created as part of the log pipeline
  # when network-node-log is started) and needs no lock.
  /command/s6-svc -u /run/service/network-node || true
fi
