#!/command/with-contenv bash
set -euo pipefail

exit_code="${1:-0}"
signal="${2:-0}"

echo "network-node finished with exit code ${exit_code}, signal ${signal}"
if [ "${exit_code}" -ne 0 ]; then
  echo "network-node exited abnormally"
fi

# On a clean exit, mark the service down so s6-rc does not auto-restart it.
if [ "${exit_code}" -eq 0 ]; then
  /command/s6-rc -d change network-node || true
fi

exit 0
